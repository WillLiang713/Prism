# 对外暴露端口（宿主机）
PRISM_PORT=3000

# 可选：Tavily 联网搜索 Key
TAVILY_API_KEY=

# 可选：Exa 联网搜索 Key
EXA_API_KEY=

# 可选：Web 端默认模型配置
# 仅在 Web 模式下生效；桌面端会忽略
# 提供商：openai / anthropic
PRISM_WEB_DEFAULT_PROVIDER=
# https://api.openai.com/
PRISM_WEB_DEFAULT_API_URL=
PRISM_WEB_DEFAULT_API_KEY=
# 端点类型：chat_completions / responses
PRISM_WEB_DEFAULT_ENDPOINT_MODE=
# 默认模型 ID，例如 gpt-5.4 / gpt-5.4-mini / deepseek-chat
PRISM_WEB_DEFAULT_MODEL=
