[
  {
    "type": "function",
    "function": {
      "name": "tavily_search",
      "description": "联网搜索最新信息并返回摘要与来源链接。仅在回答需要外部实时信息时调用。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "搜索关键词或问题。"
          },
          "search_depth": {
            "type": "string",
            "enum": [
              "basic",
              "advanced"
            ],
            "description": "搜索深度，默认 basic。"
          },
          "max_results": {
            "type": "integer",
            "description": "返回结果条数，范围 1-20。"
          },
          "include_answer": {
            "type": "boolean",
            "description": "是否返回 Tavily 生成的摘要答案。"
          },
          "include_domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "只包含这些域名。"
          },
          "exclude_domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "排除这些域名。"
          }
        },
        "required": [
          "query"
        ]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "exa_search",
      "description": "使用 Exa 联网搜索最新信息并返回来源链接。仅在回答需要外部实时信息时调用。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "搜索关键词或问题。"
          },
          "max_results": {
            "type": "integer",
            "description": "返回结果条数，范围 1-20。"
          }
        },
        "required": [
          "query"
        ]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "get_current_time",
      "description": "获取当前日期和时间。当用户询问现在几点、今天日期、星期几等时间相关问题时调用。默认返回北京时间，支持自定义时区。",
      "parameters": {
        "type": "object",
        "properties": {
          "timezone": {
            "type": "string",
            "description": "IANA 时区名称，如 Asia/Shanghai（北京时间）、America/New_York（纽约）、Europe/London（伦敦）、Asia/Tokyo（东京）等。默认为 Asia/Shanghai。"
          }
        },
        "required": []
      }
    }
  }
]
