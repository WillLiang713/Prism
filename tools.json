[
  {
    "type": "function",
    "function": {
      "name": "tavily_search",
      "description": "联网搜索最新信息并返回摘要与来源链接。仅在回答需要外部实时信息时调用。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "搜索关键词或问题。"
          },
          "search_depth": {
            "type": "string",
            "enum": [
              "basic",
              "advanced"
            ],
            "description": "搜索深度，默认 basic。"
          },
          "max_results": {
            "type": "integer",
            "description": "返回结果条数，范围 1-20。"
          },
          "include_answer": {
            "type": "boolean",
            "description": "是否返回 Tavily 生成的摘要答案。"
          },
          "include_domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "只包含这些域名。"
          },
          "exclude_domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "排除这些域名。"
          }
        },
        "required": [
          "query"
        ]
      }
    }
  }
]
