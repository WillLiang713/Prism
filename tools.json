[
  {
    "type": "function",
    "function": {
      "name": "tavily_search",
      "description": "强大的联网搜索引擎。当你需要获取最新时效信息、核实不确定的事实、或者缺乏相关知识时，请务必「优先、主动」调用此工具，不要依赖猜测。来源链接会自动展示，回复中无需重复列出。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "搜索关键词或问题。"
          },
          "search_depth": {
            "type": "string",
            "enum": [
              "basic",
              "advanced"
            ],
            "description": "搜索深度，默认 basic。"
          },
          "max_results": {
            "type": "integer",
            "description": "返回结果条数，范围 1-20。"
          },
          "include_answer": {
            "type": "boolean",
            "description": "是否返回 Tavily 生成的摘要答案。"
          },
          "include_domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "只包含这些域名。"
          },
          "exclude_domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "排除这些域名。"
          }
        },
        "required": [
          "query"
        ]
      }
    }
  },
  {
